#!/usr/bin/env bash
# shorebridge control CLI. Installed to /usr/local/bin/shorebridge.
set -euo pipefail

REPO="bretterer/shorebridge"
PREFIX="/opt/shorebridge"
ETC="/etc/shorebridge"
RAW="https://raw.githubusercontent.com/$REPO"
API="https://api.github.com/repos/$REPO"

need_root(){ [ "$(id -u)" -eq 0 ] || { echo "shorebridge $1: run with sudo" >&2; exit 1; }; }
bind_ip(){ grep -E '^\s*bind_ip' "$ETC/config.ini" 2>/dev/null | head -1 | sed 's/.*=\s*//' | tr -d '[:space:]'; }

cmd="${1:-help}"
case "$cmd" in
  update)
    need_root update
    # pin to the newest commit so GitHub's raw CDN can't serve a stale copy
    sha="$(curl -fsSL "$API/commits/main" 2>/dev/null | grep -m1 '"sha"' | cut -d'"' -f4 || true)"
    ref="${sha:-main}"
    echo "Updating shorebridge from ${ref:0:12} ..."
    tmp="$(mktemp -d)"; trap 'rm -rf "$tmp"' EXIT
    for f in shorebridge.py connectors.py; do
      curl -fsSL "$RAW/$ref/$f" -o "$tmp/$f"
    done
    python3 -c "import ast,sys; [ast.parse(open(f).read()) for f in sys.argv[1:]]" "$tmp/shorebridge.py" "$tmp/connectors.py" \
      || { echo "downloaded code failed to parse; aborting (service untouched)" >&2; exit 1; }
    install -m 0755 "$tmp/shorebridge.py" "$PREFIX/shorebridge.py"
    install -m 0644 "$tmp/connectors.py" "$PREFIX/connectors.py"
    mkdir -p "$PREFIX/connectors.d"
    if curl -fsSL "$RAW/$ref/systemd/shorebridge.service" -o "$tmp/svc" 2>/dev/null; then
      install -m 0644 "$tmp/svc" /etc/systemd/system/shorebridge.service; systemctl daemon-reload
    fi
    systemctl restart shorebridge
    sleep 1
    if systemctl is-active --quiet shorebridge; then echo "updated to ${ref:0:12} and restarted."; else
      echo "updated, but service not active - check: shorebridge logs" >&2; fi
    ;;
  logs)     journalctl -u shorebridge ${2:--f} ;;
  status)   systemctl status shorebridge --no-pager || true ;;
  restart)  need_root restart; systemctl restart shorebridge; echo "restarted." ;;
  stop)     need_root stop; systemctl stop shorebridge; echo "stopped." ;;
  start)    need_root start; systemctl start shorebridge; echo "started." ;;
  config)   need_root config; "${EDITOR:-nano}" "$ETC/config.ini"; echo "run 'shorebridge restart' to apply." ;;
  ui)       echo "http://$(bind_ip || echo localhost):8910" ;;
  *)
    cat <<EOF
shorebridge - control CLI

  shorebridge update     fetch the latest code (pinned to newest commit) and restart
  shorebridge logs       follow the service log   (shorebridge logs -n 50 for last 50)
  shorebridge status     systemd service status
  shorebridge restart    restart the service
  shorebridge start|stop start / stop the service
  shorebridge config     edit /etc/shorebridge/config.ini
  shorebridge ui         print the admin UI url
EOF
    ;;
esac
